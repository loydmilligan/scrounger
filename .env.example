# Scrounger Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE
# ===========================================
# SQLite (default - good for single Pi deployment)
DATABASE_URL=sqlite:///./data/scrounger.db

# PostgreSQL (optional - for multi-user or larger deployments)
# DATABASE_URL=postgresql://user:password@localhost:5432/scrounger

# ===========================================
# AI CONFIGURATION (OpenRouter)
# ===========================================
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default model for AI features
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Fallback model if primary is unavailable
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat

# ===========================================
# USER CONFIGURATION
# ===========================================
# Your state (for Reddit post formatting)
USER_STATE=TX

# Your ZIP code (for shipping estimates)
USER_ZIP=78701

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Debug mode (set to false in production)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===========================================
# DOCKER PORTS (only used in docker-compose)
# ===========================================
# Backend API port
BACKEND_PORT=8849

# Frontend web port
FRONTEND_PORT=8851

# ===========================================
# TIMERS (defaults, can be overridden per marketplace)
# ===========================================
# Days after delivery to request feedback
FEEDBACK_TIMER_DAYS=3

# Days after no-feedback close to send chaser
CHASER_TIMER_DAYS=14
